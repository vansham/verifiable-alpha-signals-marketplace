# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vasm:vasm@db:5432/vasm

# ── Redis / RQ ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
BASE_URL=http://localhost:8000

# ── OpenGradient ──────────────────────────────────────────────────────────────
# Set MOCK_OG=true to run fully offline with deterministic mock responses
MOCK_OG=true
OPENGRADIENT_API_KEY=
# Used for HTTP x402 fallback when SDK is not installed
OPENGRADIENT_X402_URL=https://api.opengradient.ai/v1/infer
# Model identifier to run (replace with real OG model ID)
OPENGRADIENT_MODEL_ID=og/alpha-signal-v1

# ── S3 (proof storage) ────────────────────────────────────────────────────────
# Set USE_S3=true to upload proofs to S3; otherwise saved to ./proofs/
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=vasm-proofs

# ── Discord bot (only needed for discord-bot service) ─────────────────────────
DISCORD_TOKEN=
BACKEND_API_KEY=change-me-backend-api-key
